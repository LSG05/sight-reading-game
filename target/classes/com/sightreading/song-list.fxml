<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="900.0" prefWidth="1200.0" spacing="40.0" style="-fx-background-color: #2b2b2b;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sightreading.SongListController">
   <children>
      
      <Label text="SELECT A SONG" textFill="WHITE">
         <font>
            <Font name="System Bold" size="48.0" />
         </font>
      </Label>

      <VBox alignment="CENTER" spacing="15.0">
          <Button mnemonicParsing="false" onAction="#handlePlayTwinkle" prefHeight="80.0" prefWidth="700.0" style="-fx-background-color: #4488ff; -fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold; -fx-background-radius: 10;" text="Twinkle Twinkle Little Star (80 BPM)" />
      </VBox>

      <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: #555555; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 10;" text="Back to Home" />
      
   </children>
</VBox>