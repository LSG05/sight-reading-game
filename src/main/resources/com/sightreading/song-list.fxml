<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="900.0" prefWidth="1200.0" style="-fx-background-color: #0B132B;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sightreading.SongListController">
   <children>
      
      <VBox alignment="CENTER" spacing="40.0">
         <children>
            <Label text="SELECT A SONG" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="56.0" />
               </font>
            </Label>
            <!-- change: from list to a horizontal hidden scrollbar "carousel" -->
            <ScrollPane fx:id="carouselScrollPane" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" maxWidth="1000.0" prefHeight="450.0">
               <content>
                  <HBox fx:id="carouselBox" alignment="CENTER_LEFT" spacing="30.0" style="-fx-padding: 20px;">
                     </HBox>
               </content>
            </ScrollPane>

            <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 10;" text="Back to Home" />
         </children>
      </VBox>

   </children>
</StackPane>