<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="900.0" prefWidth="1200.0" style="-fx-background-image: url('/com/sightreading/images/song_list_bg.jpg'); -fx-background-size: cover; -fx-background-position: center;"
xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sightreading.SongListController">
   <children>
      
      <VBox alignment="CENTER" spacing="40.0" style="-fx-padding: 80 0 0 0;">
         <children>
            
            <ScrollPane fx:id="carouselScrollPane" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;"
maxWidth="1000.0" prefHeight="450.0">
               <content>
                  <HBox fx:id="carouselBox" alignment="CENTER_LEFT" spacing="30.0" style="-fx-padding: 20px;">
                     </HBox>
               </content>
            </ScrollPane>

            <Button 
fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 10;"
text="Back to Home" />
         </children>
      </VBox>

   </children>
</StackPane>