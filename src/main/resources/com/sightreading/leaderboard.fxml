<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="900.0" prefWidth="1200.0" spacing="30.0" style="-fx-background-color: #2b2b2b;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sightreading.LeaderboardController">
   <children>
      
      <Label text="TOP SCORES" textFill="#4488ff">
         <font>
            <Font name="System Bold" size="56.0" />
         </font>
      </Label>

      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxWidth="600.0" prefHeight="500.0" style="-fx-background: #333333; -fx-background-color: transparent; -fx-padding: 20; -fx-border-color: #555555; -fx-border-radius: 10;">
         <content>
            <VBox fx:id="scoresContainer" alignment="TOP_CENTER" spacing="15.0" />
         </content>
      </ScrollPane>

      <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: #555555; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 10;" text="Back to Home" />
      
   </children>
</VBox>